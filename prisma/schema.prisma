generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LearningSlide {
  id         String   @id
  moduleId   String
  title      String
  layoutType String
  imageUrl   String?
  bullets    String[]
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Module {
  id                 String               @id
  slug               String               @unique
  name               String
  description        String
  tier               String
  xpPoints           Int
  orderIndex         Int
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  topicId            String?
  level              ModuleLevel?
  LearningSlide      LearningSlide[]
  Topic              Topic?               @relation(fields: [topicId], references: [id])
  QuizAttempt        QuizAttempt[]
  QuizQuestion       QuizQuestion[]
  UserModuleProgress UserModuleProgress[]

  @@index([topicId, level])
}

model QuizAttempt {
  id                String              @id
  userId            String
  moduleId          String
  totalQuestions    Int
  correctAnswers    Int
  percentage        Float
  xpEarned          Int
  attemptedAt       DateTime            @default(now())
  Module            Module              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  User              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  QuizAttemptAnswer QuizAttemptAnswer[]
}

model QuizAttemptAnswer {
  id             String       @id
  attemptId      String
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
  QuizAttempt    QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  QuizQuestion   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizQuestion {
  id                String              @id
  moduleId          String
  question          String
  optionA           String
  optionB           String
  optionC           String
  optionD           String
  correctAnswer     String
  explanation       String
  orderIndex        Int
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  QuizAttemptAnswer QuizAttemptAnswer[]
  Module            Module              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Topic {
  id          String     @id
  name        String     @unique
  description String     @default("")
  orderIndex  Int        @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  slug        String     @unique
  theme       TopicTheme @default(TECH)
  Module      Module[]
}

model User {
  id                 String               @id
  name               String
  email              String               @unique
  passwordHash       String
  role               Role                 @default(ENTHUSIAST)
  xp                 Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  eventxp            Int                  @default(0)
  QuizAttempt        QuizAttempt[]
  UserModuleProgress UserModuleProgress[]
}

model UserModuleProgress {
  id          String         @id
  userId      String
  moduleId    String
  status      ProgressStatus @default(LOCKED)
  score       Int?
  xpEarned    Int            @default(0)
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime
  Module      Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  User        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

enum ModuleLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProgressStatus {
  LOCKED
  UNLOCKED
  COMPLETED
}

enum Role {
  CORE
  CREW
  ENTHUSIAST
}

enum TopicTheme {
  TECH
  FORGE
  CITADEL
  HARBOR
  CRYSTAL
}
